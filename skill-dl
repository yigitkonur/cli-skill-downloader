#!/usr/bin/env bash
# ==============================================================================
# skill-dl — Download skills from playbooks.com (backed by GitHub)
#
# Usage:
#   skill-dl <url|file|->  [options]
#   skill-dl urls.txt --output ./my-skills --category react
#   echo "https://playbooks.com/skills/owner/repo/skill" | skill-dl -
#   skill-dl https://playbooks.com/skills/owner/repo/skill
#
# See: skill-dl --help
# ==============================================================================
set -euo pipefail

VERSION="1.0.0"
SCRIPT_NAME="$(basename "$0")"

# --- Defaults ---
OUTPUT_DIR="./skills-collection"
CATEGORY=""
AUTO_CATEGORIZE=true
PARALLEL=4
VERBOSE=false
DRY_RUN=false
FORCE=false

# --- Colors ---
if [[ -t 1 ]]; then
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[0;33m'
  BLUE='\033[0;34m'
  CYAN='\033[0;36m'
  BOLD='\033[1m'
  DIM='\033[2m'
  RESET='\033[0m'
else
  RED='' GREEN='' YELLOW='' BLUE='' CYAN='' BOLD='' DIM='' RESET=''
fi

# --- Logging ---
log()     { echo -e "${DIM}${*}${RESET}"; }
info()    { echo -e "${BLUE}[INFO]${RESET} ${*}"; }
success() { echo -e "${GREEN}[OK]${RESET}   ${*}"; }
warn()    { echo -e "${YELLOW}[WARN]${RESET} ${*}"; }
error()   { echo -e "${RED}[ERR]${RESET}  ${*}" >&2; }
debug()   { [[ "$VERBOSE" == "true" ]] && echo -e "${DIM}[DBG]  ${*}${RESET}"; }

# --- Help ---
show_help() {
  cat <<HELP
${BOLD}skill-dl${RESET} v${VERSION} — Download skills from playbooks.com

${BOLD}USAGE${RESET}
  ${SCRIPT_NAME} <source> [options]

${BOLD}SOURCE${RESET} (required, pick one)
  <url>           Single playbooks.com URL
  <file>          Text file with one URL per line (# comments allowed)
  -               Read URLs from stdin (pipe-friendly)

${BOLD}OPTIONS${RESET}
  -o, --output <dir>       Output directory (default: ./skills-collection)
  -c, --category <name>    Force all skills into this category folder
                           (overrides auto-categorization)
  --no-auto-category       Disable auto-categorization, use flat structure
  -p, --parallel <n>       Max parallel git clones (default: 4)
  -f, --force              Overwrite existing skill directories
  --dry-run                Show what would be downloaded without doing it
  -v, --verbose            Verbose output
  -h, --help               Show this help
  --version                Show version

${BOLD}URL FORMAT${RESET}
  https://playbooks.com/skills/{owner}/{repo}/{skill-name}

  Maps to GitHub:
    Repository: github.com/{owner}/{repo}
    Skill path: skills/{skill-name}/ (auto-discovered)

${BOLD}EXAMPLES${RESET}
  # Download a single skill
  ${SCRIPT_NAME} https://playbooks.com/skills/mcollina/skills/typescript-magician

  # Download from a file of URLs
  ${SCRIPT_NAME} urls.txt -o ./my-skills

  # Pipe URLs
  cat urls.txt | ${SCRIPT_NAME} - --category typescript

  # Force all into one category
  ${SCRIPT_NAME} urls.txt -c "my-typescript-skills"

  # Dry run to preview
  ${SCRIPT_NAME} urls.txt --dry-run

${BOLD}AUTO-CATEGORIZATION${RESET}
  When --category is not set, skills are auto-sorted into folders:
    strict-and-types/       typescript-strict, advanced-types, type-expert, etc.
    best-practices/         typescript, best-practices, expert, clean-typescript
    code-quality/           coding-standards, clean-code, code-style
    react-typescript/       react-typescript, react-*, nextjs-*
    pro-and-review/         typescript-pro, reviewer, code-review, magician
    sdk-and-libraries/      typescript-sdk, ts-library, typescript-v5
    tooling-and-setup/      generator, setup, init, tdd-*, circular-dependency
    general/                Everything else

${BOLD}OUTPUT STRUCTURE${RESET}
  skills-collection/
  ├── best-practices/
  │   └── mcollina--skills--typescript-magician/
  │       ├── SKILL.md
  │       └── rules/
  │           ├── generics-basics.md
  │           └── ...
  └── ...

HELP
}

# --- Parse arguments ---
SOURCES=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)    show_help; exit 0 ;;
    --version)    echo "skill-dl v${VERSION}"; exit 0 ;;
    -o|--output)  OUTPUT_DIR="$2"; shift 2 ;;
    -c|--category) CATEGORY="$2"; AUTO_CATEGORIZE=false; shift 2 ;;
    --no-auto-category) AUTO_CATEGORIZE=false; shift ;;
    -p|--parallel) PARALLEL="$2"; shift 2 ;;
    -f|--force)   FORCE=true; shift ;;
    --dry-run)    DRY_RUN=true; shift ;;
    -v|--verbose) VERBOSE=true; shift ;;
    -)            SOURCES+=("-"); shift ;;
    -*)           error "Unknown option: $1"; echo "Run '${SCRIPT_NAME} --help' for usage."; exit 1 ;;
    *)            SOURCES+=("$1"); shift ;;
  esac
done

if [[ ${#SOURCES[@]} -eq 0 ]]; then
  error "No source provided."
  echo "Run '${SCRIPT_NAME} --help' for usage."
  exit 1
fi

# --- Collect URLs from all sources ---
URLS=()

for source in "${SOURCES[@]}"; do
  if [[ "$source" == "-" ]]; then
    # Read from stdin
    while IFS= read -r line || [[ -n "$line" ]]; do
      line=$(echo "$line" | sed 's/#.*//' | xargs)  # strip comments and whitespace
      [[ -n "$line" ]] && URLS+=("$line")
    done
  elif [[ -f "$source" ]]; then
    # Read from file
    while IFS= read -r line || [[ -n "$line" ]]; do
      line=$(echo "$line" | sed 's/#.*//' | xargs)
      [[ -n "$line" ]] && URLS+=("$line")
    done < "$source"
  elif [[ "$source" =~ ^https?:// ]]; then
    # Direct URL
    URLS+=("$source")
  else
    error "Source not recognized: $source"
    error "Expected a URL, file path, or '-' for stdin."
    exit 1
  fi
done

if [[ ${#URLS[@]} -eq 0 ]]; then
  error "No URLs found in the provided source(s)."
  exit 1
fi

# --- Parse playbooks URL into owner/repo/skill ---
# Format: https://playbooks.com/skills/{owner}/{repo}/{skill}
parse_url() {
  local url="$1"
  # Strip trailing slash
  url="${url%/}"
  # Remove protocol and domain
  local path="${url#*playbooks.com/skills/}"

  if [[ "$path" == "$url" ]]; then
    echo ""
    return 1
  fi

  # Should have at least 3 segments: owner/repo/skill
  local segments
  IFS='/' read -ra segments <<< "$path"
  if [[ ${#segments[@]} -lt 3 ]]; then
    echo ""
    return 1
  fi

  local owner="${segments[0]}"
  local repo="${segments[1]}"
  # Skill name can contain slashes (remaining segments)
  local skill="${segments[*]:2}"
  skill="${skill// //}"  # join with nothing (shouldn't have spaces)
  # Actually rejoin with /
  skill=$(IFS='/'; echo "${segments[*]:2}")

  echo "${owner}|${repo}|${skill}"
}

# --- Auto-categorize based on skill name ---
categorize_skill() {
  local skill="$1"
  local name_lower
  name_lower=$(echo "$skill" | tr '[:upper:]' '[:lower:]')

  if [[ -n "$CATEGORY" ]]; then
    echo "$CATEGORY"
    return
  fi

  if [[ "$AUTO_CATEGORIZE" == "false" ]]; then
    echo ""
    return
  fi

  # Match patterns (order matters — more specific first)
  case "$name_lower" in
    *react-typescript*|*react-ts*|*nextjs-typescript*|*next-ts*)
      echo "react-typescript" ;;
    *strict*|*advanced-type*|*type-expert*|*guardian*|*detector*|*advanced-pattern*)
      echo "strict-and-types" ;;
    *sdk*|*ts-library*|*typescript-v*|*library*)
      echo "sdk-and-libraries" ;;
    *review*|*reviewer*|*pro-skill*|*magician*|*code-review*)
      echo "pro-and-review" ;;
    *generator*|*setup*|*init*|*tdd-*|*circular*|*tooling*|*lang-typescript*|*bun-*)
      echo "tooling-and-setup" ;;
    *coding-standard*|*code-standard*|*clean-code*|*code-style*|*best-practice*|*check-try*)
      echo "code-quality" ;;
    *typescript*|*expert*|*clean-typescript*|*javascript-typescript*)
      echo "best-practices" ;;
    *)
      echo "general" ;;
  esac
}

# --- Find skill directory in a cloned repo ---
find_skill_dir() {
  local clone_dir="$1"
  local skill="$2"

  # Try known paths in order of likelihood
  local paths=(
    "skills/${skill}"
    "${skill}"
    ".skills/${skill}"
    ".claude/skills/${skill}"
    ".agent/skills/${skill}"
    ".opencode/skills/${skill}"
    ".cursor/skills/${skill}"
    ".agents/skills/${skill}"
    "src/skills/${skill}"
  )

  for try_path in "${paths[@]}"; do
    if [[ -d "${clone_dir}/${try_path}" ]]; then
      echo "${clone_dir}/${try_path}"
      return 0
    fi
  done

  # Fallback: recursive search for SKILL.md matching skill name
  local found
  found=$(find "$clone_dir" -name "SKILL.md" -path "*${skill}*" 2>/dev/null | head -1)
  if [[ -n "$found" ]]; then
    dirname "$found"
    return 0
  fi

  return 1
}

# --- Clone and extract a single skill ---
process_skill() {
  local url="$1"
  local index="$2"
  local total="$3"

  # Parse URL
  local parsed
  parsed=$(parse_url "$url") || true
  if [[ -z "$parsed" ]]; then
    error "[${index}/${total}] Invalid URL: ${url}"
    echo "FAIL|${url}|invalid URL format"
    return
  fi

  IFS='|' read -r owner repo skill <<< "$parsed"
  local category
  category=$(categorize_skill "$skill")
  local folder_name="${owner}--${repo}--${skill}"

  # Build destination path
  local dest
  if [[ -n "$category" ]]; then
    dest="${OUTPUT_DIR}/${category}/${folder_name}"
  else
    dest="${OUTPUT_DIR}/${folder_name}"
  fi

  # Dry run
  if [[ "$DRY_RUN" == "true" ]]; then
    info "[${index}/${total}] ${owner}/${repo}/${skill} → ${dest}"
    echo "DRY|${url}|${dest}"
    return
  fi

  # Skip if exists and not forcing
  if [[ -d "$dest" && "$FORCE" != "true" ]]; then
    warn "[${index}/${total}] Already exists: ${folder_name} (use --force to overwrite)"
    echo "SKIP|${url}|${dest}"
    return
  fi

  info "[${index}/${total}] ${CYAN}${owner}/${repo}${RESET} → ${BOLD}${skill}${RESET}"
  debug "  Category: ${category:-<flat>}"
  debug "  Dest: ${dest}"

  # Create temp dir for this clone
  local temp_clone
  temp_clone=$(mktemp -d)

  # Shallow clone
  if ! git clone --depth 1 --quiet "https://github.com/${owner}/${repo}.git" "$temp_clone" 2>/dev/null; then
    error "  Could not clone github.com/${owner}/${repo}"
    rm -rf "$temp_clone"
    echo "FAIL|${url}|repo clone failed"
    return
  fi

  debug "  Cloned ${owner}/${repo}"

  # Find the skill directory
  local skill_dir
  if skill_dir=$(find_skill_dir "$temp_clone" "$skill"); then
    # Clean and copy
    [[ -d "$dest" ]] && rm -rf "$dest"
    mkdir -p "$dest"
    cp -r "${skill_dir}/." "$dest/"

    # Remove any .git artifacts that might have been copied
    rm -rf "${dest}/.git"

    local file_count
    file_count=$(find "$dest" -type f | wc -l | tr -d ' ')
    success "  ${file_count} files → ${category:-<root>}/${folder_name}"
    echo "OK|${url}|${dest}|${file_count}"
  else
    error "  Skill '${skill}' not found in ${owner}/${repo}"
    # Show available skills for debugging
    if [[ "$VERBOSE" == "true" && -d "${temp_clone}/skills" ]]; then
      debug "  Available skills: $(ls "${temp_clone}/skills/" 2>/dev/null | tr '\n' ' ')"
    fi
    echo "FAIL|${url}|skill directory not found"
  fi

  # Cleanup
  rm -rf "$temp_clone"
}

# --- Main ---

echo ""
echo -e "${BOLD}skill-dl${RESET} v${VERSION}"
echo -e "${DIM}Downloading ${#URLS[@]} skill(s) into: ${OUTPUT_DIR}${RESET}"
echo ""

mkdir -p "$OUTPUT_DIR"

# Deduplicate URLs
declare -A SEEN_URLS
UNIQUE_URLS=()
for url in "${URLS[@]}"; do
  url="${url%/}"
  if [[ -z "${SEEN_URLS[$url]:-}" ]]; then
    SEEN_URLS[$url]=1
    UNIQUE_URLS+=("$url")
  else
    debug "Skipping duplicate: $url"
  fi
done

if [[ ${#UNIQUE_URLS[@]} -ne ${#URLS[@]} ]]; then
  info "Deduplicated: ${#URLS[@]} → ${#UNIQUE_URLS[@]} unique URLs"
fi

# --- Group by repo for efficiency (clone each repo once) ---
declare -A REPO_TO_SKILLS  # "owner/repo" → "skill1|cat1|url1 skill2|cat2|url2 ..."
declare -a REPO_ORDER      # preserve insertion order

for url in "${UNIQUE_URLS[@]}"; do
  parsed=$(parse_url "$url") || true
  if [[ -z "$parsed" ]]; then
    continue
  fi
  IFS='|' read -r owner repo skill <<< "$parsed"
  repo_key="${owner}/${repo}"

  category=$(categorize_skill "$skill")
  folder_name="${owner}--${repo}--${skill}"

  entry="${skill}|${category}|${url}|${folder_name}"

  if [[ -z "${REPO_TO_SKILLS[$repo_key]:-}" ]]; then
    REPO_TO_SKILLS[$repo_key]="$entry"
    REPO_ORDER+=("$repo_key")
  else
    REPO_TO_SKILLS[$repo_key]+=$'\n'"$entry"
  fi
done

total=${#UNIQUE_URLS[@]}
current=0
ok_count=0
fail_count=0
skip_count=0
failed_list=()

for repo_key in "${REPO_ORDER[@]}"; do
  owner=$(echo "$repo_key" | cut -d'/' -f1)
  repo=$(echo "$repo_key" | cut -d'/' -f2)

  # Count skills in this repo
  skill_count=$(echo "${REPO_TO_SKILLS[$repo_key]}" | wc -l | tr -d ' ')

  if [[ "$DRY_RUN" != "true" ]]; then
    log "─── ${repo_key} (${skill_count} skill$([ "$skill_count" -gt 1 ] && echo s)) ───"
  fi

  # Clone repo once
  temp_clone=$(mktemp -d)
  clone_ok=true

  if [[ "$DRY_RUN" != "true" ]]; then
    if ! git clone --depth 1 --quiet "https://github.com/${repo_key}.git" "$temp_clone" 2>/dev/null; then
      error "Could not clone github.com/${repo_key}"
      clone_ok=false
    fi
  fi

  # Process each skill from this repo
  while IFS='|' read -r skill category url folder_name; do
    current=$((current + 1))

    if [[ -n "$category" ]]; then
      dest="${OUTPUT_DIR}/${category}/${folder_name}"
    else
      dest="${OUTPUT_DIR}/${folder_name}"
    fi

    # Dry run
    if [[ "$DRY_RUN" == "true" ]]; then
      info "[${current}/${total}] ${owner}/${repo}/${skill} → ${dest}"
      skip_count=$((skip_count + 1))
      continue
    fi

    # Clone failed
    if [[ "$clone_ok" != "true" ]]; then
      error "[${current}/${total}] ${skill} — repo unavailable"
      fail_count=$((fail_count + 1))
      failed_list+=("${url}")
      continue
    fi

    # Skip if exists
    if [[ -d "$dest" && "$FORCE" != "true" ]]; then
      warn "[${current}/${total}] Exists: ${folder_name} (--force to overwrite)"
      skip_count=$((skip_count + 1))
      continue
    fi

    info "[${current}/${total}] ${CYAN}${skill}${RESET}"

    # Find skill dir
    local_skill_dir=""
    if local_skill_dir=$(find_skill_dir "$temp_clone" "$skill"); then
      [[ -d "$dest" ]] && rm -rf "$dest"
      mkdir -p "$dest"
      cp -r "${local_skill_dir}/." "$dest/"
      rm -rf "${dest}/.git"

      file_count=$(find "$dest" -type f | wc -l | tr -d ' ')
      success "  ${file_count} files → ${category:+${category}/}${folder_name}"
      ok_count=$((ok_count + 1))
    else
      error "  Not found in repo"
      fail_count=$((fail_count + 1))
      failed_list+=("${url}")
      if [[ "$VERBOSE" == "true" && -d "${temp_clone}/skills" ]]; then
        debug "  Available: $(ls "${temp_clone}/skills/" 2>/dev/null | head -10 | tr '\n' ' ')"
      fi
    fi

  done <<< "${REPO_TO_SKILLS[$repo_key]}"

  # Cleanup clone
  rm -rf "$temp_clone"
done

# --- Summary ---
echo ""
echo -e "${BOLD}━━━ Summary ━━━${RESET}"
echo -e "  Total:   ${total}"
[[ $ok_count -gt 0 ]]   && echo -e "  ${GREEN}Success: ${ok_count}${RESET}"
[[ $skip_count -gt 0 ]] && echo -e "  ${YELLOW}Skipped: ${skip_count}${RESET}"
[[ $fail_count -gt 0 ]] && echo -e "  ${RED}Failed:  ${fail_count}${RESET}"

if [[ ${#failed_list[@]} -gt 0 ]]; then
  echo ""
  echo -e "${RED}Failed URLs:${RESET}"
  for f in "${failed_list[@]}"; do
    echo "  $f"
  done
fi

if [[ "$DRY_RUN" != "true" && $ok_count -gt 0 ]]; then
  echo ""
  echo -e "${DIM}Output: ${OUTPUT_DIR}${RESET}"
  echo -e "${DIM}Size:   $(du -sh "$OUTPUT_DIR" 2>/dev/null | cut -f1)${RESET}"
fi

echo ""

# Exit code: 0 if all succeeded, 1 if any failed
[[ $fail_count -eq 0 ]]
