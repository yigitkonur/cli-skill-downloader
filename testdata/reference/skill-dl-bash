#!/usr/bin/env bash
# ==============================================================================
# skill-dl — Download skills from playbooks.com (backed by GitHub)
#
# Usage:
#   skill-dl <url|file|->  [options]
#   skill-dl urls.txt --output ./my-skills --category react
#   echo "https://playbooks.com/skills/owner/repo/skill" | skill-dl -
#   skill-dl https://playbooks.com/skills/owner/repo/skill
#
# See: skill-dl --help
# ==============================================================================
set -euo pipefail

VERSION="1.3.0"
SCRIPT_NAME="$(basename "$0")"

# --- Defaults ---
OUTPUT_DIR="./skills-collection"
CATEGORY=""
AUTO_CATEGORIZE=true
VERBOSE=false
DRY_RUN=false
FORCE=false

# --- API Keys (environment overrides hardcoded defaults) ---
SERPER_API_KEY="${SERPER_API_KEY:-a3c7a6122cb26d80c6a975e41b2a1047eb746b59}"
SCRAPEDO_API_KEY="${SCRAPEDO_API_KEY:-d4874c0918ad49b782ce649c642364a5561da9e8387}"

# --- Colors (disabled when piped) ---
if [[ -t 1 ]]; then
  RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[0;33m'
  BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'
  DIM='\033[2m'; RESET='\033[0m'
else
  RED=''; GREEN=''; YELLOW=''; BLUE=''; CYAN=''; BOLD=''; DIM=''; RESET=''
fi

# --- Logging (all to stderr so stdout stays clean for data) ---
log()     { echo -e "${DIM}${*}${RESET}" >&2; }
info()    { echo -e "${BLUE}[INFO]${RESET} ${*}" >&2; }
success() { echo -e "${GREEN}[OK]${RESET}   ${*}" >&2; }
warn()    { echo -e "${YELLOW}[WARN]${RESET} ${*}" >&2; }
error()   { echo -e "${RED}[ERR]${RESET}  ${*}" >&2; }
debug()   { [[ "$VERBOSE" == "true" ]] && echo -e "${DIM}[DBG]  ${*}${RESET}" >&2 || true; }

# ==============================================================================
# SEARCH SUBCOMMAND
# Invoked when the first positional argument is "search".
# Runs independently and exits — never falls through to download logic.
# ==============================================================================
cmd_search() {
  # ---- Parse search-specific arguments ----------------------------------------
  local keywords=()
  local top_n=0        # 0 = no limit
  local min_match=1

  # Consume "search" itself (already verified by caller)
  shift

  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    cat <<EOF
skill-dl search — Discover skills via Google (Serper) + playbooks.com

USAGE
  ${SCRIPT_NAME} search <keyword1> <keyword2> ... [options]

  Requires 3-20 keywords. Searches using all available backends,
  then ranks skills by how many keywords they match.

SEARCH BACKENDS (auto-detected)
  Serper API    Google-powered, finds skills across all of playbooks.com
                Set SERPER_API_KEY env var or uses built-in key
  Playbooks     Direct HTML scraping (always active, 3 pages per keyword)
  Scrapedo      Proxy fallback when direct requests are blocked
                Set SCRAPEDO_API_KEY env var or uses built-in key

OPTIONS
  --top <N>         Show only top N results (default: all)
  --min-match <N>   Only show skills matching N+ keywords (default: 1)
  -h, --help        Show this help

EXAMPLES
  skill-dl search typescript react nextjs testing vitest
  skill-dl search "browser automation" playwright puppeteer --top 20
  skill-dl search mcp server sdk client tools --min-match 2
  SERPER_API_KEY=xxx skill-dl search openclaw agent skill --top 30
EOF
    exit 0
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --top)
        [[ -z "${2:-}" || ! "${2}" =~ ^[0-9]+$ ]] && { error "--top requires a positive integer"; exit 1; }
        top_n="$2"; shift 2 ;;
      --min-match)
        [[ -z "${2:-}" || ! "${2}" =~ ^[0-9]+$ ]] && { error "--min-match requires a positive integer"; exit 1; }
        min_match="$2"; shift 2 ;;
      -*)
        error "Unknown search option: $1"; echo "Run '${SCRIPT_NAME} search --help' for usage." >&2; exit 1 ;;
      *)
        keywords+=("$1"); shift ;;
    esac
  done

  # ---- Validate keyword count --------------------------------------------------
  local kw_count=${#keywords[@]}
  if [[ $kw_count -lt 3 ]]; then
    error "search requires at least 3 keywords (got ${kw_count})."
    echo "Run '${SCRIPT_NAME} search --help' for usage." >&2
    exit 1
  fi
  if [[ $kw_count -gt 20 ]]; then
    error "search accepts at most 20 keywords (got ${kw_count})."
    echo "Run '${SCRIPT_NAME} search --help' for usage." >&2
    exit 1
  fi

  echo "[search] Searching for ${kw_count} keyword(s)..." >&2

  # ---- Scrape in parallel, one temp file per keyword/page ---------------------
  local tmp_dir
  tmp_dir=$(mktemp -d)
  trap 'rm -rf "$tmp_dir"' EXIT

  local pids=()
  local kw_idx=0

  # Determine which search backends are available
  local use_serper=false
  local use_scrapedo=false
  if [[ -n "${SERPER_API_KEY:-}" ]]; then
    use_serper=true
    echo "[search] Serper API enabled (Google-powered discovery)" >&2
  fi
  if [[ -n "${SCRAPEDO_API_KEY:-}" ]]; then
    use_scrapedo=true
    echo "[search] Scrapedo proxy enabled (fallback for blocked requests)" >&2
  fi

  for kw in "${keywords[@]}"; do
    local out_file="${tmp_dir}/kw_${kw_idx}"
    touch "$out_file"
    kw_idx=$((kw_idx + 1))

    # --- Inline all logic in the subshell (avoids function visibility issues) ---
    (
      # Backend 1: Serper API (Google search)
      if [[ "$use_serper" == "true" ]]; then
        serper_resp=$(curl -sL --max-time 15 \
          -X POST "https://google.serper.dev/search" \
          -H "X-API-KEY: ${SERPER_API_KEY}" \
          -H "Content-Type: application/json" \
          -d "{\"q\": \"site:playbooks.com/skills ${kw}\", \"num\": 30}" 2>/dev/null) || true
        if [[ -n "$serper_resp" ]]; then
          echo "$serper_resp" \
            | grep -oE 'https://playbooks\.com/skills/[^"]+' \
            | sed 's|https://playbooks\.com||; s|\\$||; s|/$||' \
            | grep -E '^/skills/[^/]+/[^/]+/[^/]+$' \
            | grep -v '[?#\\]' \
            | sort -u >> "$out_file"
        fi
      fi

      # Backend 2: Direct playbooks.com scraping (with Scrapedo fallback)
      enc_kw=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$kw" 2>/dev/null \
        || printf '%s' "$kw" | sed 's/ /%20/g; s/!/%21/g; s/"/%22/g; s/#/%23/g; s/\$/%24/g; s/&/%26/g; s/+/%2B/g')

      for page in 1 2 3; do
        pg_url="https://playbooks.com/skills?search=${enc_kw}&page=${page}"
        html=$(curl -sL --max-time 12 "$pg_url" 2>/dev/null) || true

        # Fallback to Scrapedo if direct fetch returned too little
        if [[ ${#html} -lt 200 && "$use_scrapedo" == "true" ]]; then
          enc_target=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$pg_url" 2>/dev/null || echo "$pg_url")
          html=$(curl -sL --max-time 20 "https://api.scrapedo.com/scrape?url=${enc_target}&token=${SCRAPEDO_API_KEY}&render=false&super=false" 2>/dev/null) || true
        fi

        if [[ -n "$html" ]]; then
          echo "$html" \
            | grep -oE '/skills/[^"<> ]+' \
            | grep -E '^/skills/[^/]+/[^/]+/[^/]+$' \
            | grep -v '[?#]' \
            | sort -u >> "$out_file"
        fi
      done

      # Clean and deduplicate: strip trailing backslashes, whitespace, empty lines
      if [[ -s "$out_file" ]]; then
        sed -i '' 's/\\*$//; s/[[:space:]]*$//' "$out_file" 2>/dev/null \
          || sed -i 's/\\*$//; s/[[:space:]]*$//' "$out_file"
        grep -E '^/skills/[^/]+/[^/]+/[^/]+$' "$out_file" | sort -u > "${out_file}.clean"
        mv "${out_file}.clean" "$out_file"
      fi
    ) &

    pids+=($!)
  done

  # Wait for all background fetches
  for pid in "${pids[@]}"; do
    wait "$pid" 2>/dev/null || true
  done

  # Count total unique results across all keywords for reporting
  local total_raw=0
  for f in "${tmp_dir}"/kw_*; do
    [[ -f "$f" && -s "$f" ]] && total_raw=$((total_raw + $(wc -l < "$f" | tr -d ' ')))
  done
  echo "[search] Raw results: ${total_raw} skill references across ${kw_count} keywords" >&2

  echo "[search] Aggregating results..." >&2

  # ---- Aggregate: skill_path -> keyword match count + which keywords ----------
  # skill_path is like /skills/owner/repo/skill-name
  declare -A skill_kw_count   # skill_path -> integer count
  declare -A skill_kw_list    # skill_path -> comma-separated keyword list

  kw_idx=0
  for kw in "${keywords[@]}"; do
    local out_file="${tmp_dir}/kw_${kw_idx}"
    kw_idx=$((kw_idx + 1))

    if [[ ! -f "$out_file" ]]; then continue; fi

    # Read unique skill paths from this keyword's results
    local prev=""
    while IFS= read -r skill_path; do
      [[ -z "$skill_path" || "$skill_path" == "$prev" ]] && continue
      prev="$skill_path"

      if [[ -z "${skill_kw_count[$skill_path]:-}" ]]; then
        skill_kw_count[$skill_path]=1
        skill_kw_list[$skill_path]="$kw"
      else
        skill_kw_count[$skill_path]=$(( skill_kw_count[$skill_path] + 1 ))
        skill_kw_list[$skill_path]="${skill_kw_list[$skill_path]}, $kw"
      fi
    done < <(sort -u "$out_file")
  done

  # ---- Filter by --min-match --------------------------------------------------
  local filtered_paths=()
  for skill_path in "${!skill_kw_count[@]}"; do
    local cnt="${skill_kw_count[$skill_path]}"
    [[ $cnt -ge $min_match ]] && filtered_paths+=("$skill_path")
  done

  if [[ ${#filtered_paths[@]} -eq 0 ]]; then
    echo "No skills found matching the given keywords (min-match=${min_match})." >&2
    exit 1
  fi

  # ---- Sort: by match count desc, then skill path asc ------------------------
  # Build a sortable list: "count|skill_path" -> sort numerically desc then alpha
  local sort_file="${tmp_dir}/sort_input"
  for skill_path in "${filtered_paths[@]}"; do
    echo "${skill_kw_count[$skill_path]}|${skill_path}"
  done | sort -t'|' -k1,1rn -k2,2 > "$sort_file"

  # ---- Apply --top limit ------------------------------------------------------
  local result_paths=()
  while IFS='|' read -r _cnt path; do
    result_paths+=("$path")
    if [[ $top_n -gt 0 && ${#result_paths[@]} -ge $top_n ]]; then break; fi
  done < "$sort_file"

  # ---- Render markdown table --------------------------------------------------
  # Output to STDOUT (no colors, no ANSI)
  printf '| # | Skill | Owner/Repo | Keywords Matched | Match Count | URL |\n'
  printf '|---|-------|------------|-----------------|-------------|-----|\n'

  local row=1
  for skill_path in "${result_paths[@]}"; do
    # skill_path = /skills/owner/repo/skill-name
    local stripped="${skill_path#/skills/}"   # owner/repo/skill-name
    local owner_repo
    owner_repo=$(echo "$stripped" | cut -d'/' -f1-2)   # owner/repo
    local skill_name
    skill_name=$(echo "$stripped" | cut -d'/' -f3-)      # skill-name (may contain /)

    local cnt="${skill_kw_count[$skill_path]}"
    local matched_kws="${skill_kw_list[$skill_path]}"
    local full_url="https://playbooks.com${skill_path}"

    printf '| %d | %s | %s | %s | %d | %s |\n' \
      "$row" "$skill_name" "$owner_repo" "$matched_kws" "$cnt" "$full_url"

    row=$((row + 1))
  done

  echo "" >&2
  echo "[search] Done. ${#result_paths[@]} skill(s) shown (from ${#filtered_paths[@]} total matched)." >&2
  exit 0
}

# --- Help ---
show_help() {
  cat <<EOF
skill-dl v${VERSION} — Download skills from playbooks.com (with Serper + Scrapedo)

USAGE
  ${SCRIPT_NAME} <source> [options]

SOURCE (required, one or more)
  <url>           Single playbooks.com URL
  <file>          Text file with one URL per line (# comments allowed)
  -               Read URLs from stdin (pipe-friendly)

OPTIONS
  -o, --output <dir>       Output directory (default: ./skills-collection)
  -c, --category <name>    Force all skills into this category folder
  --no-auto-category       Flat structure, no category folders
  -f, --force              Overwrite existing skill directories
  --dry-run                Preview without downloading
  -v, --verbose            Debug output
  -h, --help               Show this help
  --version                Show version

ENVIRONMENT
  SERPER_API_KEY           Google search via serper.dev (built-in default)
  SCRAPEDO_API_KEY         Scraping proxy via scrapedo.com (built-in default)

URL FORMAT
  https://playbooks.com/skills/{owner}/{repo}/{skill-name}

WHAT GETS DOWNLOADED
  Subdirectory skills: the entire skill directory is copied.
  Root-level skills:   everything except repo metadata is copied.

  Excluded repo metadata:
    .git, .github, .gitlab, node_modules, .vscode, .idea
    README.md, LICENSE, CHANGELOG.md, CONTRIBUTING.md,
    .gitignore, package.json, lockfiles

  Everything else (SKILL.md, references/, rules/, examples/,
  or any custom folder) is included automatically.

EXAMPLES
  # Single skill
  ${SCRIPT_NAME} https://playbooks.com/skills/mcollina/skills/typescript-magician

  # Multiple skills inline
  ${SCRIPT_NAME} \\
    https://playbooks.com/skills/mcollina/skills/typescript-magician \\
    https://playbooks.com/skills/nickcrew/claude-cortex/typescript-advanced-patterns \\
    https://playbooks.com/skills/greyhaven-ai/claude-code-config/tdd-typescript

  # From a file (one URL per line, # comments supported)
  ${SCRIPT_NAME} urls.txt -o ./my-skills

  # Mix URLs and files
  ${SCRIPT_NAME} urls.txt https://playbooks.com/skills/inkeep/skills/typescript-sdk

  # Pipe from another command
  cat urls.txt | ${SCRIPT_NAME} -

  # Force all into one category folder
  ${SCRIPT_NAME} urls.txt -c my-typescript-skills

  # Dry run to preview what would be downloaded
  ${SCRIPT_NAME} urls.txt --dry-run

  # Re-download everything (overwrite existing)
  ${SCRIPT_NAME} urls.txt --force
EOF
}

# --- Dispatch search subcommand before normal argument parsing ---
if [[ "${1:-}" == "search" ]]; then
  cmd_search "$@"
  # cmd_search always exits; this line is never reached
fi

# --- Parse arguments ---
SOURCES=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)         show_help; exit 0 ;;
    --version)         echo "skill-dl v${VERSION}"; exit 0 ;;
    -o|--output)       OUTPUT_DIR="$2"; shift 2 ;;
    -c|--category)     CATEGORY="$2"; AUTO_CATEGORIZE=false; shift 2 ;;
    --no-auto-category) AUTO_CATEGORIZE=false; shift ;;
    -f|--force)        FORCE=true; shift ;;
    --dry-run)         DRY_RUN=true; shift ;;
    -v|--verbose)      VERBOSE=true; shift ;;
    -)                 SOURCES+=("-"); shift ;;
    -*)                error "Unknown option: $1"; echo "Run '${SCRIPT_NAME} --help' for usage."; exit 1 ;;
    *)                 SOURCES+=("$1"); shift ;;
  esac
done

if [[ ${#SOURCES[@]} -eq 0 ]]; then
  error "No source provided."
  echo "" >&2
  show_help >&2
  exit 1
fi

# --- Collect URLs from all sources ---
URLS=()

for source in "${SOURCES[@]}"; do
  if [[ "$source" == "-" ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
      line=$(echo "$line" | sed 's/#.*//' | xargs)
      [[ -n "$line" ]] && URLS+=("$line")
    done
  elif [[ -f "$source" ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
      line=$(echo "$line" | sed 's/#.*//' | xargs)
      [[ -n "$line" ]] && URLS+=("$line")
    done < "$source"
  elif [[ "$source" =~ ^https?:// ]]; then
    URLS+=("$source")
  else
    error "Source not recognized: $source (expected URL, file, or '-')"
    exit 1
  fi
done

if [[ ${#URLS[@]} -eq 0 ]]; then
  error "No URLs found in the provided source(s)."
  exit 1
fi

# --- Parse playbooks URL → owner/repo/skill ---
parse_url() {
  local url="$1"
  url="${url%/}"
  local path="${url#*playbooks.com/skills/}"
  [[ "$path" == "$url" ]] && return 1

  local segments
  IFS='/' read -ra segments <<< "$path"
  [[ ${#segments[@]} -lt 3 ]] && return 1

  local owner="${segments[0]}"
  local repo="${segments[1]}"
  local skill
  skill=$(IFS='/'; echo "${segments[*]:2}")

  echo "${owner}|${repo}|${skill}"
}

# --- Auto-categorize by skill name ---
categorize_skill() {
  local skill="$1"

  if [[ -n "$CATEGORY" ]]; then
    echo "$CATEGORY"; return
  fi
  if [[ "$AUTO_CATEGORIZE" == "false" ]]; then
    echo ""; return
  fi

  local name_lower
  name_lower=$(echo "$skill" | tr '[:upper:]' '[:lower:]')

  case "$name_lower" in
    *react-typescript*|*react-ts*|*nextjs-typescript*|*next-ts*)
      echo "react-typescript" ;;
    *strict*|*advanced-type*|*type-expert*|*guardian*|*detector*|*advanced-pattern*)
      echo "strict-and-types" ;;
    *sdk*|*ts-library*|*typescript-v*|*library*)
      echo "sdk-and-libraries" ;;
    *review*|*reviewer*|*pro-skill*|*magician*|*code-review*)
      echo "pro-and-review" ;;
    *generator*|*setup*|*init*|*tdd-*|*circular*|*tooling*|*lang-typescript*|*bun-*)
      echo "tooling-and-setup" ;;
    *coding-standard*|*code-standard*|*clean-code*|*code-style*|*best-practice*|*check-try*)
      echo "code-quality" ;;
    *typescript*|*expert*|*clean-typescript*|*javascript-typescript*)
      echo "best-practices" ;;
    *)
      echo "general" ;;
  esac
}

# ==============================================================================
# find_skill_dir — Precisely locate a skill directory inside a cloned repo.
#
# Strategy (in order):
#   1. Try known paths where skills are commonly stored
#   2. Search for SKILL.md where the PARENT DIRECTORY NAME exactly matches
#      the skill name (prevents false matches from repo path)
#   3. If the repo root has SKILL.md and no skills/ subdirectory, treat the
#      repo itself as a single-skill repo (return special marker "ROOT")
# ==============================================================================
find_skill_dir() {
  local clone_dir="$1"
  local skill="$2"

  # --- 1. Try known paths (require SKILL.md to exist) ---
  local paths=(
    "skills/${skill}"
    "${skill}"
    ".skills/${skill}"
    ".claude/skills/${skill}"
    ".agent/skills/${skill}"
    ".opencode/skills/${skill}"
    ".cursor/skills/${skill}"
    ".agents/skills/${skill}"
    "src/skills/${skill}"
  )

  for try_path in "${paths[@]}"; do
    if [[ -f "${clone_dir}/${try_path}/SKILL.md" ]]; then
      debug "    Found at known path: ${try_path}/"
      echo "${clone_dir}/${try_path}"
      return 0
    fi
  done

  # --- 2. Search all SKILL.md files, match by parent dir name ---
  local found=""
  while IFS= read -r skill_md; do
    local parent_dir
    parent_dir=$(dirname "$skill_md")
    local dir_name
    dir_name=$(basename "$parent_dir")
    if [[ "$dir_name" == "$skill" ]]; then
      found="$parent_dir"
      debug "    Found via search: ${parent_dir#$clone_dir/}"
      break
    fi
  done < <(find "$clone_dir" -name "SKILL.md" -not -path "*/.git/*" 2>/dev/null)

  if [[ -n "$found" ]]; then
    echo "$found"
    return 0
  fi

  # --- 3. Root-level skill: repo itself IS the skill ---
  if [[ -f "${clone_dir}/SKILL.md" ]]; then
    debug "    Found at repo root (single-skill repo)"
    echo "ROOT:${clone_dir}"
    return 0
  fi

  return 1
}

# ==============================================================================
# copy_skill — Copy skill files from source to destination.
#
# For subdirectory skills: copies the entire directory.
# For root-level skills: selectively copies SKILL.md + known skill subdirs,
#   skipping repo metadata (README.md, LICENSE, .github/, etc.)
# ==============================================================================
copy_skill() {
  local source="$1"
  local dest="$2"
  local is_root=false

  # Check if this is a root-level skill
  if [[ "$source" == ROOT:* ]]; then
    source="${source#ROOT:}"
    is_root=true
  fi

  [[ -d "$dest" ]] && rm -rf "$dest"
  mkdir -p "$dest"

  if [[ "$is_root" == "true" ]]; then
    # Root-level skill: copy everything EXCEPT known repo metadata.
    # This is an exclusion approach — any directory or file the skill
    # author creates (guides/, snippets/, recipes/, etc.) is included
    # automatically without needing to update a whitelist.
    local exclude_dirs=".git .github .gitlab node_modules .vscode .idea"
    local exclude_files="README.md LICENSE LICENSE.md CHANGELOG.md CONTRIBUTING.md CODE_OF_CONDUCT.md SECURITY.md .gitignore .gitattributes package.json package-lock.json yarn.lock pnpm-lock.yaml bun.lockb"

    # Copy visible files and directories (skip excluded)
    for f in "${source}"/*; do
      [[ ! -e "$f" ]] && continue
      local fname
      fname=$(basename "$f")
      if [[ -d "$f" ]]; then
        echo "$exclude_dirs" | grep -qw "$fname" && continue
        cp -r "$f" "$dest/"
      else
        echo "$exclude_files" | grep -qw "$fname" && continue
        cp "$f" "$dest/"
      fi
    done

    # Copy dotfiles that aren't excluded (e.g. .editorconfig for skills)
    for f in "${source}"/.*; do
      [[ ! -e "$f" ]] && continue
      local fname
      fname=$(basename "$f")
      [[ "$fname" == "." || "$fname" == ".." ]] && continue
      echo "$exclude_dirs $exclude_files" | grep -qw "$fname" && continue
      if [[ -d "$f" ]]; then
        cp -r "$f" "$dest/"
      else
        cp "$f" "$dest/"
      fi
    done
  else
    # Subdirectory skill: copy everything
    cp -r "${source}/." "$dest/"
  fi

  # Always clean up git artifacts
  rm -rf "${dest}/.git"

  # Count and return
  find "$dest" -type f | wc -l | tr -d ' '
}

# --- Main ---

echo "" >&2
echo -e "${BOLD}skill-dl${RESET} v${VERSION}" >&2
echo -e "${DIM}Downloading ${#URLS[@]} skill(s) into: ${OUTPUT_DIR}${RESET}" >&2
echo "" >&2

mkdir -p "$OUTPUT_DIR"

# Deduplicate URLs
declare -A SEEN_URLS
UNIQUE_URLS=()
for url in "${URLS[@]}"; do
  url="${url%/}"
  if [[ -z "${SEEN_URLS[$url]:-}" ]]; then
    SEEN_URLS[$url]=1
    UNIQUE_URLS+=("$url")
  else
    debug "Skipping duplicate: $url"
  fi
done

if [[ ${#UNIQUE_URLS[@]} -ne ${#URLS[@]} ]]; then
  info "Deduplicated: ${#URLS[@]} → ${#UNIQUE_URLS[@]} unique URLs"
fi

# --- Group by repo (clone each repo only once) ---
declare -A REPO_TO_SKILLS
declare -a REPO_ORDER

for url in "${UNIQUE_URLS[@]}"; do
  parsed=$(parse_url "$url") || true
  if [[ -z "$parsed" ]]; then
    error "Invalid URL (skipped): $url"
    continue
  fi
  IFS='|' read -r owner repo skill <<< "$parsed"
  repo_key="${owner}/${repo}"
  category=$(categorize_skill "$skill")
  folder_name="${owner}--${repo}--${skill}"
  entry="${skill}|${category}|${url}|${folder_name}"

  if [[ -z "${REPO_TO_SKILLS[$repo_key]:-}" ]]; then
    REPO_TO_SKILLS[$repo_key]="$entry"
    REPO_ORDER+=("$repo_key")
  else
    REPO_TO_SKILLS[$repo_key]+=$'\n'"$entry"
  fi
done

total=${#UNIQUE_URLS[@]}
current=0
ok_count=0
fail_count=0
skip_count=0
failed_list=()

for repo_key in "${REPO_ORDER[@]}"; do
  owner=$(echo "$repo_key" | cut -d'/' -f1)
  repo=$(echo "$repo_key" | cut -d'/' -f2)
  skill_count=$(echo "${REPO_TO_SKILLS[$repo_key]}" | wc -l | tr -d ' ')

  if [[ "$DRY_RUN" != "true" ]]; then
    log "─── ${repo_key} (${skill_count} skill$([ "$skill_count" -gt 1 ] && echo s)) ───"
  fi

  # Clone repo once
  temp_clone=$(mktemp -d)
  clone_ok=true

  if [[ "$DRY_RUN" != "true" ]]; then
    if ! git clone --depth 1 --quiet "https://github.com/${repo_key}.git" "$temp_clone" 2>/dev/null; then
      error "Could not clone github.com/${repo_key}"
      clone_ok=false
    fi
  fi

  # Process each skill from this repo
  while IFS='|' read -r skill category url folder_name; do
    current=$((current + 1))

    if [[ -n "$category" ]]; then
      dest="${OUTPUT_DIR}/${category}/${folder_name}"
    else
      dest="${OUTPUT_DIR}/${folder_name}"
    fi

    # Dry run
    if [[ "$DRY_RUN" == "true" ]]; then
      info "[${current}/${total}] ${owner}/${repo}/${skill} → ${dest}"
      skip_count=$((skip_count + 1))
      continue
    fi

    # Clone failed
    if [[ "$clone_ok" != "true" ]]; then
      error "[${current}/${total}] ${skill} — repo unavailable"
      fail_count=$((fail_count + 1))
      failed_list+=("${url}")
      continue
    fi

    # Skip if exists
    if [[ -d "$dest" && "$FORCE" != "true" ]]; then
      warn "[${current}/${total}] Exists: ${folder_name} (--force to overwrite)"
      skip_count=$((skip_count + 1))
      continue
    fi

    info "[${current}/${total}] ${CYAN}${skill}${RESET}"

    # Find and copy skill
    local_skill_dir=""
    if local_skill_dir=$(find_skill_dir "$temp_clone" "$skill"); then
      file_count=$(copy_skill "$local_skill_dir" "$dest")
      success "  ${file_count} files → ${category:+${category}/}${folder_name}"
      ok_count=$((ok_count + 1))
    else
      error "  Not found in repo"
      fail_count=$((fail_count + 1))
      failed_list+=("${url}")
      if [[ "$VERBOSE" == "true" ]]; then
        # Show what skills actually exist in the repo
        avail=""
        avail=$(find "$temp_clone" -name "SKILL.md" -not -path "*/.git/*" 2>/dev/null | while read -r f; do
          basename "$(dirname "$f")"
        done | sort -u | tr '\n' ' ')
        [[ -n "$avail" ]] && debug "  Available skills: ${avail}"
      fi
    fi

  done <<< "${REPO_TO_SKILLS[$repo_key]}"

  rm -rf "$temp_clone"
done

# --- Summary ---
echo "" >&2
echo -e "${BOLD}━━━ Summary ━━━${RESET}" >&2
echo -e "  Total:   ${total}" >&2
[[ $ok_count -gt 0 ]]   && echo -e "  ${GREEN}Success: ${ok_count}${RESET}" >&2
[[ $skip_count -gt 0 ]] && echo -e "  ${YELLOW}Skipped: ${skip_count}${RESET}" >&2
[[ $fail_count -gt 0 ]] && echo -e "  ${RED}Failed:  ${fail_count}${RESET}" >&2

if [[ ${#failed_list[@]} -gt 0 ]]; then
  echo "" >&2
  echo -e "${RED}Failed URLs:${RESET}" >&2
  for f in "${failed_list[@]}"; do
    echo "  $f" >&2
  done
fi

if [[ "$DRY_RUN" != "true" && $ok_count -gt 0 ]]; then
  echo "" >&2
  echo -e "${DIM}Output: ${OUTPUT_DIR}${RESET}" >&2
  echo -e "${DIM}Size:   $(du -sh "$OUTPUT_DIR" 2>/dev/null | cut -f1)${RESET}" >&2
fi

echo "" >&2
[[ $fail_count -eq 0 ]]
